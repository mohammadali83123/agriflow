# ─── Database ───────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string.
# Create a free project at https://console.neon.tech, then paste the
# "Connection string" from the dashboard here.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ─── Auth (Better Auth) — added in Sprint 1 ─────────────────────────────────
# Generate a random secret: openssl rand -base64 32
BETTER_AUTH_SECRET=

# The canonical URL this app runs at (no trailing slash).
# Local dev:   http://localhost:3000
# Production:  https://your-app.vercel.app
BETTER_AUTH_URL=http://localhost:3000

# ─── Public vars (safe to expose to the browser) ────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
