{
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npm run db:generate)",
      "Bash(npm run db:migrate)",
      "Bash(npm install*)",
      "Bash(npx @better-auth/cli*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git status)",
      "Bash(git diff*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*)",
      "Bash(rm -rf*)"
    ]
  }
}
